# 复制为 .env 并填入你自己的值;不要把真实密钥提交到仓库。
# 用法:先 source .env,或用 python-dotenv 加载,或直接 export 各变量。
# 下面的默认值与 config.py 保持一致;只有 MEALMATE_API_KEY 必须自己填。

# ---- 中转 API(OpenAI 兼容) ----
MEALMATE_API_BASE=https://api.inferera.com/v1
MEALMATE_API_KEY=在这里填你的密钥切勿提交

# ---- 三个 LLM 分别指定模型 ----
# 默认都用快模型 Haiku,黑客松现场演示更跟手;
# 若更看重对话文风,可把 MEALMATE_CHAT_MODEL 换成 Opus(如 claude-opus-4-8)。
MEALMATE_INTENT_MODEL=claude-haiku-4-5-20251001
MEALMATE_CHAT_MODEL=claude-haiku-4-5-20251001
MEALMATE_PREF_MODEL=claude-haiku-4-5-20251001

# ---- 调用参数(可选,不设则用括号内默认值) ----
MEALMATE_INTENT_TEMP=0        # 意图识别温度(默认 0,要确定性)
MEALMATE_CHAT_TEMP=0.7        # 对话温度(默认 0.7,活一点)
MEALMATE_TIMEOUT=12           # 单次请求超时秒数(默认 12)
MEALMATE_LLM_RETRIES=1        # 网络抖动时的额外重试次数(默认 1)

# 新版 Claude 模型(如 claude-opus-4-8)不再接受 temperature 参数,默认不发送。
# 若你的模型/中转支持并想显式发送温度,置为 1。
MEALMATE_SEND_TEMPERATURE=0

# ---- Web 服务监听地址(可选) ----
MEALMATE_HOST=127.0.0.1       # 默认 127.0.0.1
MEALMATE_PORT=8000            # 默认 8000

# ==== 语音入口(唤醒词 + 豆包流式 ASR;可选) ====
# 不需要语音时,置 MEALMATE_VOICE_ENABLED=0 即可,文本对话不受影响。
MEALMATE_VOICE_ENABLED=1
MEALMATE_VOICE_HOST=127.0.0.1
MEALMATE_VOICE_PORT=8765       # 浏览器语音 WebSocket 网关端口(独立于 HTTP 端口)
MEALMATE_WAKE_WORD=小瓜小瓜
MEALMATE_EMBED_AGENT=1         # 内嵌 agent 客户端:把识别文本回灌给 server.process

# ---- 豆包流式 ASR(只在服务端使用,切勿提交真实密钥) ----
DOUBAO_APP_ID=在这里填豆包应用ID
DOUBAO_ACCESS_TOKEN=在这里填豆包AccessToken
# Access Token WebSocket 流程不使用 Secret Key;仅为部署环境兼容保留。
DOUBAO_SECRET_KEY=
DOUBAO_RESOURCE_ID=volc.bigasr.sauc.duration
DOUBAO_ASR_ENDPOINT=wss://openspeech.bytedance.com/api/v3/sauc/bigmodel_async

# 可选:不设置时使用 models/ 下由 scripts/setup_kws.py 下载的默认模型
# KWS_MODEL_DIR=/绝对路径/sherpa-onnx-kws-zipformer-zh-en-3M-2025-12-20

# ---- 本地语句结束检测 ----
MEALMATE_SILENCE_MS=900
MEALMATE_NO_SPEECH_MS=4000
MEALMATE_MAX_UTTERANCE_MS=12000
MEALMATE_SPEECH_THRESHOLD=500

# ==== 机器人语音输出(可选;把 agent 回复用机器人扬声器念出来) ====
# 配置后,每条 agent 回复会经 edge-tts 合成并 POST 到机器人播放服务(robot/robot_player.py)。
# 不配置则完全不启用,Web 行为不变。需要:Web 端装 edge-tts 且系统有 ffmpeg。
# HEYRICE_ROBOT_TTS_URL=http://机器人IP:5002/play
# HEYRICE_ROBOT_TTS_VOICE=zh-CN-XiaoxiaoNeural

