# 复制为 .env 并填入你自己的值;不要把真实密钥提交到仓库。
# 用法:先 source .env,或用 python-dotenv 加载,或直接 export 各变量。
# 下面的默认值与 config.py 保持一致;只有 MEALMATE_API_KEY 必须自己填。

# ---- 中转 API(OpenAI 兼容) ----
MEALMATE_API_BASE=https://api.inferera.com/v1
MEALMATE_API_KEY=在这里填你的密钥切勿提交

# ---- 三个 LLM 分别指定模型 ----
# 默认都用快模型 Haiku,黑客松现场演示更跟手;
# 若更看重对话文风,可把 MEALMATE_CHAT_MODEL 换成 Opus(如 claude-opus-4-8)。
MEALMATE_INTENT_MODEL=claude-haiku-4-5-20251001
MEALMATE_CHAT_MODEL=claude-haiku-4-5-20251001
MEALMATE_PREF_MODEL=claude-haiku-4-5-20251001

# ---- 调用参数(可选,不设则用括号内默认值) ----
MEALMATE_INTENT_TEMP=0        # 意图识别温度(默认 0,要确定性)
MEALMATE_CHAT_TEMP=0.7        # 对话温度(默认 0.7,活一点)
MEALMATE_TIMEOUT=12           # 单次请求超时秒数(默认 12)
MEALMATE_LLM_RETRIES=1        # 网络抖动时的额外重试次数(默认 1)

# 新版 Claude 模型(如 claude-opus-4-8)不再接受 temperature 参数,默认不发送。
# 若你的模型/中转支持并想显式发送温度,置为 1。
MEALMATE_SEND_TEMPERATURE=0

# ---- Web 服务监听地址(可选) ----
MEALMATE_HOST=127.0.0.1       # 默认 127.0.0.1
MEALMATE_PORT=8000            # 默认 8000
