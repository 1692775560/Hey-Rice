# 复制为 .env 并填入你自己的值;不要把真实密钥提交到仓库。
# 用法:先 source 或用 python-dotenv 加载,或直接 export。

# 中转 API(OpenAI 兼容)
MEALMATE_API_BASE=https://api.inferera.com/v1
MEALMATE_API_KEY=在这里填你的密钥切勿提交

# 两个 LLM 分别指定模型(可相同,也可对话用更快的)
MEALMATE_INTENT_MODEL=claude-opus-4-8
MEALMATE_CHAT_MODEL=claude-opus-4-8

# 可选调参
MEALMATE_INTENT_TEMP=0
MEALMATE_CHAT_TEMP=0.7
MEALMATE_TIMEOUT=20
